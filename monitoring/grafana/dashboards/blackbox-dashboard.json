{
  "id": null,
  "title": "Blackbox Exporter",
  "tags": ["blackbox", "prometheus"],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Probe Success",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "probe_success" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "graph",
      "title": "HTTP Response Time",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "probe_duration_seconds" }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "stat",
      "title": "HTTP Status Code",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "probe_http_status_code" }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 }
    }
  ]
}
